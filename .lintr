linters: linters_with_defaults(
    # SONG uses the algorithm's mathematical notation (W, Y, X, D, E_s, E_q)
    # to mirror the reference paper and the C++ core; these are deliberate and
    # are part of the public model-object contract, so naming style is relaxed.
    object_name_linter = NULL,
    # "# Python: ..." comments document the port against the reference and are
    # intentional provenance, not dead code.
    commented_code_linter = NULL,
    line_length_linter = line_length_linter(100L)
  )
exclusions: list(
    "R/RcppExports.R",  # generated by Rcpp::compileAttributes()
    # resolve_color_by() is defined in song-helpers.R; lintr's per-file
    # object_usage analysis cannot see cross-file package internals, so it
    # false-flags the calls in plot.song_model() / autoplot.song_model().
    "R/song-plot.R" = list(object_usage_linter = Inf)
  )
